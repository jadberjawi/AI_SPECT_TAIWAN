data/volumes/
data/labels/
data/local_volumes/
data/local_labels/
data/normalized/
data/simple_normalized/
data/seg/

# Top-level raw/ (DICOM + NIfTI) — never commit
raw/

# Common medical-imaging extensions, anywhere in the tree
*.nii
*.nii.gz
*.dcm
*.mhd
*.mha
*.nrrd

